<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ tool }} Docs — {{ site.title }}</title>
  <meta name="description" content="{{ description }}">
  <link rel="canonical" href="{{ site.url }}{{ page.url }}">
  {% include "shared-css.njk" %}
  <style>
    .tool-tabs { border-bottom: 1px solid var(--border); }
    .tool-tabs .container { display: flex; gap: 0; }
    .tool-tabs a {
      color: var(--text-muted); text-decoration: none;
      padding: 0.65rem 1rem; font-size: 0.8rem;
      border-bottom: 2px solid transparent; margin-bottom: -1px;
      transition: color 0.1s, border-color 0.1s; white-space: nowrap;
    }
    .tool-tabs a:hover { color: var(--heading); text-decoration: none; }
    .tool-tabs a.active { color: var(--accent); border-bottom-color: var(--accent); }

    main { padding: 3rem 0; }
    .docs-hub-header { margin-bottom: 3rem; }
    .docs-hub-title { margin-bottom: 0.5rem; }
    .docs-hub-desc { color: var(--text-muted); margin: 0; max-width: 560px; font-size: 0.9rem; }

    .docs-toc { display: grid; grid-template-columns: 1fr 1fr; gap: 0 3rem; }
    @media (max-width: 640px) { .docs-toc { grid-template-columns: 1fr; } }

    .docs-section { margin-bottom: 2.25rem; }
    .docs-section-label {
      font-size: 0.6rem; font-weight: 700; text-transform: uppercase;
      letter-spacing: 0.14em; color: var(--text-muted);
      margin: 0 0 0.5rem;
    }
    .docs-section-list { list-style: none; margin: 0; padding: 0; border-top: 1px solid var(--border); }
    .docs-section-list li { border-bottom: 1px solid var(--border); }
    .docs-page-link {
      display: flex; align-items: baseline; justify-content: space-between;
      gap: 1.5rem; padding: 0.65rem 0;
      text-decoration: none; transition: color 0.1s;
    }
    .docs-page-link:hover { text-decoration: none; }
    .docs-page-link:hover .docs-page-title { color: var(--accent); }
    .docs-page-title { font-size: 0.875rem; color: var(--heading); flex-shrink: 0; }
    .docs-page-desc { font-size: 0.75rem; color: var(--text-muted); text-align: right; line-height: 1.4; min-width: 0; }
  </style>
</head>
<body>
  {% include "nav.njk" %}

  {% set toolData = null %}
  {% for t in site.tools %}{% if t.name === tool %}{% set toolData = t %}{% endif %}{% endfor %}

  <div class="tool-tabs">
    <div class="container">
      <a href="/{{ tool }}/">Overview</a>
      <a href="/{{ tool }}/docs/" class="active">Docs</a>
      {% if toolData and toolData.tutorialsUrl %}<a href="{{ toolData.tutorialsUrl }}">Tutorials</a>{% endif %}
    </div>
  </div>

  <main>
    <div class="container">
      <div class="docs-hub-header">
        <h1 class="docs-hub-title">{{ tool }} Documentation</h1>
        <p class="docs-hub-desc">{{ description }}</p>
      </div>

      {% set docNav = toolnav[tool] if toolnav[tool] else nav %}
      {% if docNav %}
      <div class="docs-toc">
        {% for section in docNav %}
        <div class="docs-section">
          <p class="docs-section-label">{{ section.section }}</p>
          <ul class="docs-section-list">
            {% for item in section.pages %}
            <li>
              <a href="/{{ tool }}/docs/{{ item.slug }}/" class="docs-page-link">
                <span class="docs-page-title">{{ item.title }}</span>
                {% if item.desc %}<span class="docs-page-desc">{{ item.desc }}</span>{% endif %}
              </a>
            </li>
            {% endfor %}
          </ul>
        </div>
        {% endfor %}
      </div>
      {% endif %}

    </div>
  </main>

  {% include "footer.njk" %}
</body>
</html>
