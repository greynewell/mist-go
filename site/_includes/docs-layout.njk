<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} — {{ tool }} docs — {{ site.title }}</title>
  <meta name="description" content="{{ description }}">
  <link rel="canonical" href="{{ site.url }}{{ page.url }}">
  {% include "shared-css.njk" %}
  <style>
    /* Tool tab bar */
    .tool-tabs {
      border-bottom: 1px solid var(--border);
      background: var(--bg);
    }
    .tool-tabs .container { display: flex; gap: 0; }
    .tool-tabs a {
      color: var(--text-muted);
      text-decoration: none;
      padding: 0.65rem 1rem;
      font-size: 0.8rem;
      border-bottom: 2px solid transparent;
      margin-bottom: -1px;
      transition: color 0.1s, border-color 0.1s;
      white-space: nowrap;
    }
    .tool-tabs a:hover { color: var(--heading); text-decoration: none; }
    .tool-tabs a.active { color: var(--accent); border-bottom-color: var(--accent); }

    /* Docs wrapper */
    .docs-wrapper { display: flex; min-height: calc(100vh - 300px); }

    /* Sidebar */
    .docs-sidebar {
      width: 252px;
      flex-shrink: 0;
      border-right: 1px solid var(--border);
      padding: 1.5rem 0 2rem;
      position: sticky;
      top: 49px; /* height of site-nav */
      height: calc(100vh - 49px);
      overflow-y: auto;
    }
    .sidebar-tool-header {
      padding: 0 1.25rem 1.25rem;
      border-bottom: 1px solid var(--border);
      margin-bottom: 1.25rem;
    }
    .sidebar-tool-name {
      font-size: 0.875rem;
      font-weight: 700;
      color: var(--heading);
    }
    .sidebar-tool-name a { color: var(--heading); text-decoration: none; }
    .sidebar-tool-name a:hover { color: var(--accent); }
    .sidebar-tool-sub { font-size: 0.72rem; color: var(--text-muted); margin-top: 0.15rem; }

    .sidebar-section { padding: 0 1rem; margin-bottom: 1.25rem; }
    .sidebar-section-label {
      font-size: 0.62rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: var(--text-muted);
      margin-bottom: 0.35rem;
      display: block;
      padding: 0 0.35rem;
    }
    .sidebar-link {
      display: block;
      font-size: 0.8rem;
      color: var(--text-muted);
      text-decoration: none;
      padding: 0.22rem 0.5rem;
      border-radius: 4px;
      line-height: 1.5;
      transition: color 0.1s, background 0.1s;
    }
    .sidebar-link:hover { color: var(--heading); background: var(--bg-card); text-decoration: none; }
    .sidebar-link.active { color: var(--accent); background: var(--bg-card); font-weight: 500; }

    /* Docs main */
    .docs-main {
      flex: 1;
      min-width: 0;
      padding: 2.5rem 3rem;
      max-width: 820px;
    }

    /* Doc content */
    .docs-content { }
    .docs-content h1 { font-size: 1.8rem; margin-bottom: 0.6rem; border-bottom: 1px solid var(--border); padding-bottom: 1rem; }
    .docs-content h2 { font-size: 1.25rem; margin-top: 2.5rem; margin-bottom: 0.75rem; scroll-margin-top: 1rem; }
    .docs-content h3 { font-size: 1.05rem; margin-top: 2rem; margin-bottom: 0.6rem; scroll-margin-top: 1rem; }
    .docs-content h4 { font-size: 0.9rem; margin-top: 1.5rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em; }
    .docs-content .doc-meta { color: var(--text-muted); font-size: 0.8rem; margin-bottom: 2rem; display: flex; gap: 0.75rem; align-items: center; }

    /* Callout boxes */
    .callout {
      border-left: 3px solid var(--border);
      padding: 0.75rem 1rem;
      margin: 1.5rem 0;
      background: var(--bg-card);
      border-radius: 0 6px 6px 0;
      font-size: 0.875rem;
    }
    .callout.note { border-color: var(--accent-dim); }
    .callout.warning { border-color: #b45309; }
    .callout.tip { border-color: #15803d; }
    .callout p:last-child { margin-bottom: 0; }

    /* Prev/Next */
    .docs-prevnext {
      display: flex;
      justify-content: space-between;
      margin-top: 3rem;
      padding-top: 1.5rem;
      border-top: 1px solid var(--border);
      gap: 1rem;
    }
    .pn-item { display: flex; flex-direction: column; gap: 0.2rem; max-width: 45%; }
    .pn-item a { color: var(--text-muted); text-decoration: none; }
    .pn-item a:hover { color: var(--accent); }
    .pn-label { font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-muted); }
    .pn-title { font-size: 0.875rem; font-weight: 500; color: var(--heading); }
    .pn-next { text-align: right; margin-left: auto; }

    /* Responsive */
    @media (max-width: 900px) {
      .docs-main { padding: 1.5rem; }
    }
    @media (max-width: 720px) {
      .docs-wrapper { flex-direction: column; }
      .docs-sidebar { width: 100%; height: auto; position: static; border-right: none; border-bottom: 1px solid var(--border); padding: 1rem 0; }
      .docs-main { padding: 1.5rem 1rem; }
    }
  </style>
</head>
<body>
  {% include "nav.njk" %}

  {% set toolData = null %}
  {% for t in site.tools %}{% if t.name === tool %}{% set toolData = t %}{% endif %}{% endfor %}

  <div class="tool-tabs">
    <div class="container">
      <a href="/{{ tool }}/">Overview</a>
      <a href="/{{ tool }}/docs/" class="active">Docs</a>
      {% if toolData and toolData.tutorialsUrl %}<a href="{{ toolData.tutorialsUrl }}">Tutorials</a>{% endif %}
    </div>
  </div>

  <div class="docs-wrapper">
    <aside class="docs-sidebar">
      <div class="sidebar-tool-header">
        <div class="sidebar-tool-name"><a href="/{{ tool }}/">{{ tool }}</a></div>
        <div class="sidebar-tool-sub">Documentation</div>
      </div>
      {% if nav %}
        {% for section in nav %}
        <div class="sidebar-section">
          <span class="sidebar-section-label">{{ section.section }}</span>
          {% for item in section.pages %}
          {% set itemUrl = "/" + tool + "/docs/" + item.slug + "/" %}
          <a href="{{ itemUrl }}" class="sidebar-link{% if page.url == itemUrl %} active{% endif %}">{{ item.title }}</a>
          {% endfor %}
        </div>
        {% endfor %}
      {% endif %}
    </aside>

    <div class="docs-main">
      <div class="docs-content">
        {{ content | safe }}
      </div>

      {% if nav %}
      {% set pn = nav | prevNext(page.fileSlug) %}
      <div class="docs-prevnext">
        {% if pn.prev %}
        <div class="pn-item">
          <span class="pn-label">← Previous</span>
          <a href="/{{ tool }}/docs/{{ pn.prev.slug }}/"><span class="pn-title">{{ pn.prev.title }}</span></a>
        </div>
        {% else %}<div></div>{% endif %}
        {% if pn.next %}
        <div class="pn-item pn-next">
          <span class="pn-label">Next →</span>
          <a href="/{{ tool }}/docs/{{ pn.next.slug }}/"><span class="pn-title">{{ pn.next.title }}</span></a>
        </div>
        {% endif %}
      </div>
      {% endif %}
    </div>
  </div>

  {% include "footer.njk" %}
  <script>
    document.querySelectorAll('.terminal-body').forEach(function(el) {
      el.innerHTML = el.textContent.split('\n').map(function(line) {
        var t = line.trimStart();
        if (t.startsWith('#')) return '<span style="color:#6a9955">' + line + '</span>';
        if (t.startsWith('$') || t.startsWith('>')) return '<span style="color:#4ec9b0">' + line + '</span>';
        if (/error|Error|FAIL|fatal/i.test(line)) return '<span style="color:#f48771">' + line + '</span>';
        if (/\bok\b|PASS|✓|success|done/i.test(line)) return '<span style="color:#4ec9b0">' + line + '</span>';
        return line;
      }).join('\n');
    });
  </script>
</body>
</html>
